{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/mnemcik/cg-extensions-registry/main/schema/cg-extension.schema.json",
  "title": "Consigliere extension manifest (cg-extension.json)",
  "type": "object",
  "required": ["manifest", "name", "version", "description", "contributes"],
  "additionalProperties": false,
  "properties": {
    "manifest": {
      "type": "integer",
      "const": 1,
      "description": "Manifest schema version. v1 = 1."
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Install name, .cg.json key, clone dir, ext:<name>:section namespace, and cg-<name> binary stem."
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+",
      "description": "Extension semver."
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "contributes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "claude-md-sections": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "path"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
              "path": { "type": "string", "minLength": 1 }
            }
          }
        },
        "notes": {
          "type": "array",
          "items": { "$ref": "#/$defs/copy" }
        },
        "hooks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["event", "wrapper", "command"],
            "additionalProperties": false,
            "properties": {
              "event": { "type": "string", "minLength": 1 },
              "wrapper": { "type": "string", "minLength": 1 },
              "command": { "type": "string", "minLength": 1 }
            }
          }
        },
        "subcommands": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["namespace", "binary"],
            "additionalProperties": false,
            "properties": {
              "namespace": { "type": "string", "pattern": "^[a-z0-9-]+$" },
              "binary": { "type": "string", "pattern": "^[a-z0-9-]+$" }
            }
          }
        },
        "templates": {
          "type": "array",
          "items": { "$ref": "#/$defs/copy" }
        }
      }
    }
  },
  "$defs": {
    "copy": {
      "type": "object",
      "required": ["src", "dest"],
      "additionalProperties": false,
      "properties": {
        "src": { "type": "string", "minLength": 1 },
        "dest": { "type": "string", "minLength": 1 }
      }
    }
  }
}
